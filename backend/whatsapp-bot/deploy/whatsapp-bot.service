[Unit]
Description=PowerConcept WhatsApp Bot
After=network.target docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/POWERCONCEPT_LOVEBLE/backend/whatsapp-bot
EnvironmentFile=/root/POWERCONCEPT_LOVEBLE/backend/whatsapp-bot/.env
ExecStart=/root/POWERCONCEPT_LOVEBLE/backend/whatsapp-bot/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
